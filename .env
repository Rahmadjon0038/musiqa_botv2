# All Media Downloader API: YouTube/TikTok/Instagram link yuborsangiz, bot shu API orqali video va audio (mp3) uchun to‘g‘ridan-to‘g‘ri download linklarni olib keladi, keyin Telegram’ga 🎥 Video yoki 🎵 MP3 qilib yuboradi.
PGSSLMODE=disable
# RapidAPI hosts/base URLs (set these to the exact values shown on each RapidAPI API "Endpoints" page)
# Universal media downloader
MEDIA_API_BASEURL=https://auto-download-all-in-one.p.rapidapi.com
MEDIA_API_HOST=auto-download-all-in-one.p.rapidapi.com
MEDIA_API_PATH=/v1/social/autolink
MEDIA_API_METHOD=POST

# YouTube search + MP3 converter (Yt-API)
YT_API_BASEURL=https://youtube-mp3-audio-video-downloader.p.rapidapi.com
YT_API_HOST=youtube-mp3-audio-video-downloader.p.rapidapi.com
YT_API_SEARCH_PATH=/search_video
YT_API_SEARCH_PARAM=query
YT_API_DL_PATH=/dl
YT_API_DL_PARAM=id
YT_API_DL_QUALITY=

# Optional: use a DIFFERENT RapidAPI app for download (if the downloader endpoint is locked on your plan)
# Example: set these to https://youtube-mp36.p.rapidapi.com and youtube-mp36.p.rapidapi.com and also set:
#   YT_API_DL_PATH=/dl
#   YT_API_DL_PARAM=id
YT_DL_BASEURL=https://youtube-mp36.p.rapidapi.com
YT_DL_HOST=youtube-mp36.p.rapidapi.com

# YouTube MP4/Audio downloader with real quality options
YT_VIDEO_API_BASEURL=https://youtube-video-fast-downloader-24-7.p.rapidapi.com
YT_VIDEO_API_HOST=youtube-video-fast-downloader-24-7.p.rapidapi.com
YT_VIDEO_QUALITIES_PATH=/get_available_quality/{id}
YT_VIDEO_DOWNLOAD_PATH=/download_video/{id}
YT_VIDEO_AUDIO_PATH=/download_audio/{id}
YT_VIDEO_TIMEOUT_MS=60000

# Shazam detect (optional; if not set, Identify Song will fail)
SHAZAM_API_BASEURL=https://shazam-core.p.rapidapi.com
SHAZAM_API_HOST=shazam-core.p.rapidapi.com
SHAZAM_DETECT_PATH=/v1/tracks/recognize
# Shazam Core expects x-www-form-urlencoded with a "file" field.
# Set SHAZAM_FILE_MODE=url to send the downloadable audio URL, or base64 to send a base64 snippet.
SHAZAM_CONTENT_TYPE=multipart/form-data
SHAZAM_FILE_FIELD=file
SHAZAM_FILE_MODE=base64
SHAZAM_SAMPLE_BYTES=2000000
SHAZAM_TIMEOUT_MS=60000
SHAZAM_SAMPLE_BYTES=8000000
